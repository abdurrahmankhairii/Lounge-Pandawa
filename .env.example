# ===== APPLICATION =====
APP_ENV=development
APP_NAME="Arjuna Smart Lounge"
APP_VERSION="2.0.0"
APP_BASE_URL=http://localhost:3555
API_V1_PREFIX=/api/v1
DEBUG=True

# ===== DATABASE =====
DB_HOST=db
DB_PORT=5432
DB_NAME=arjuna_lounge_db
DB_USER=arjuna_user
DB_PASSWORD=arjuna_dev_password
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ===== REDIS =====
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ===== SECURITY =====
SECRET_KEY=dev-secret-key-change-in-production-64-chars-minimum-required!!
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== MIDTRANS =====
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_IS_PRODUCTION=False

# ===== WHATSAPP =====
WA_API_URL=https://graph.facebook.com/v19.0
WA_TOKEN=
WA_PHONE_ID=

# ===== EMAIL =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@arjunalounge.id

# ===== LOUNGE SETTINGS =====
LOUNGE_ID=arjuna-vip-01
DEFAULT_SLOT_CAPACITY=20
SLOT_DURATION_MINUTES=60
